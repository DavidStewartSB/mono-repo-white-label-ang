{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@cardapio-online/agendamento": [
        "libs/featureds/agendamento/src/index.ts"
      ],
      "@cardapio-online/auth": ["libs/core/auth/src/index.ts"],
      "@cardapio-online/breadcrumb": [
        "libs/components/breadcrumb/src/index.ts"
      ],
      "@cardapio-online/button": ["libs/components/button/src/index.ts"],
      "@cardapio-online/categories": ["libs/featureds/categories/src/index.ts"],
      "@cardapio-online/company": ["libs/featureds/company/src/index.ts"],
      "@cardapio-online/config": ["libs/core/config/src/index.ts"],
      "@cardapio-online/dashboard": [
        "libs/featureds/admin/dashboard/src/index.ts"
      ],
      "@cardapio-online/drawer": ["libs/components/drawer/src/index.ts"],
      "@cardapio-online/forms": ["libs/components/forms/src/index.ts"],
      "@cardapio-online/http": ["libs/core/http/src/index.ts"],
      "@cardapio-online/input-photo": [
        "libs/components/input-photo/src/index.ts"
      ],
      "@cardapio-online/inputs": ["libs/components/inputs/src/index.ts"],
      "@cardapio-online/loaders": ["libs/components/loaders/src/index.ts"],
      "@cardapio-online/loading": ["libs/core/loading/src/index.ts"],
      "@cardapio-online/login": ["libs/featureds/login/src/index.ts"],
      "@cardapio-online/media": ["libs/core/media/src/index.ts"],
      "@cardapio-online/onboarding": ["libs/core/onboarding/src/index.ts"],
      "@cardapio-online/orders": ["libs/featureds/orders/src/index.ts"],
      "@cardapio-online/products-admin": [
        "libs/featureds/admin/products-admin/src/index.ts"
      ],
      "@cardapio-online/produtos": ["libs/featureds/public/produtos/src/index.ts"],
      "@cardapio-online/shell": ["libs/core/shell/src/index.ts"],
      "@cardapio-online/tables": ["libs/components/table/src/index.ts"],
      "@cardapio-online/tenant": ["libs/core/tenant/src/index.ts"],
      "@cardapio-online/tooltip": ["libs/components/tooltips/src/index.ts"],
      "@components/*": ["libs/components/*/src/index.ts"],
      "@components/button": ["libs/components/button/src/index.ts"],
      "@env/blend-food": ["apps/blend-food/src/environments/environment.ts"],
      "@env/ju-marmitaria": [
        "apps/ju-marmitaria/src/environments/environment.ts"
      ],
      "@featureds/*": ["libs/featureds/*/src/index.ts"],
      "@featureds/agendamento": ["libs/featureds/agendamento/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
