{
  "name": "ju-marmitaria",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/ju-marmitaria/src",
  "tags": ["type:app"],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ju-marmitaria",
        "index": "apps/ju-marmitaria/src/index.html",
        "browser": "apps/ju-marmitaria/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/ju-marmitaria/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/ju-marmitaria/src/favicon.ico",
          "apps/ju-marmitaria/src/assets"
        ],
        "styles": ["apps/ju-marmitaria/src/styles.scss"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "all",
           "fileReplacements": [
            {
              "replace": "apps/ju-marmitaria/src/environments/environment.ts",
              "with": "apps/ju-marmitaria/src/environments/environment.prod.ts"
            }
          ]
        },
             "dev": {
                  "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/ju-marmitaria/src/environments/environment.ts",
              "with": "apps/ju-marmitaria/src/environments/environment.dev.ts"
            }
          ]
        },
         "local": {
          "fileReplacements": [
            {
              "replace": "apps/ju-marmitaria/src/environments/environment.ts",
              "with": "apps/ju-marmitaria/src/environments/environment.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
   "configurations": {
        "local": { "buildTarget": "ju-marmitaria:build:local" },
        "dev": { "buildTarget": "ju-marmitaria:build:dev" },
        "prod": { "buildTarget": "ju-marmitaria:build:prod" }
      },
      "defaultConfiguration": "local"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "ju-marmitaria:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/ju-marmitaria/jest.config.ts"
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "ju-marmitaria:build",
        "port": 4200,
        "staticFilePath": "dist/apps/ju-marmitaria/browser",
        "spa": true
      }
    }
  }
}
